# --- Aplicacion ---
PROJECT_NAME=Mini RAG Lab
VERSION=1.0.0
DEBUG=True
API_PREFIX=/api

# --- Servidor (uvicorn) ---
HOST=127.0.0.1
PORT=8000

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mini_rag_lab
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# --- Qdrant ---
QDRANT_HOST=localhost
QDRANT_PORT=6333

# --- Ollama ---
OLLAMA_URL=http://localhost:11434

# --- CORS: origenes del frontend Angular (formato JSON) ---
BACKEND_CORS_ORIGINS=["http://localhost:4200"]
